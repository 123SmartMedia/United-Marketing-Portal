# Normalize line endings: store text as LF in the repo, check out native on Windows.
# Eliminates the "LF will be replaced by CRLF" warnings.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
*.mp4 binary
*.mov binary
*.webm binary
*.docx binary
*.ico binary
