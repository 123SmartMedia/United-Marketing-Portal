# Copy to .env.local and fill in for form email delivery.
# Without RESEND_API_KEY the site still runs; submissions are logged to the
# server console instead of emailed (useful for local dev / staging).

# Resend API key — https://resend.com  (free tier covers this volume)
RESEND_API_KEY=

# Where request-form submissions are delivered (matches the current site).
REQUEST_EMAIL=marketingdesk@unitedmortgage.com

# Verified sender for Resend. The domain must be verified in Resend before
# production. Use a marketing.unitedmortgage.com sender once DNS is set up.
FROM_EMAIL="United Marketing Desk <no-reply@marketing.unitedmortgage.com>"
