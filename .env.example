# Copy to .env.local and fill in for form email delivery.
# Without RESEND_API_KEY the site still runs; submissions are logged to the
# server console instead of emailed (useful for local dev / staging).

# Resend API key — https://resend.com  (free tier covers this volume)
RESEND_API_KEY=

# Where request-form submissions are delivered.
REQUEST_EMAIL=marketing@unitedmortgage.com

# Verified sender for Resend. The FROM domain must be verified in Resend before
# production (SPF/DKIM DNS records). To send AS marketing@unitedmortgage.com you
# must verify unitedmortgage.com in Resend; otherwise send from a verified
# subdomain and keep Reply-To as marketing@unitedmortgage.com.
FROM_EMAIL="United Marketing Desk <marketing@unitedmortgage.com>"

# --- Assets (Cloudflare R2) ---
# Runtime base URL for assets. Set in Vercel env to the R2 public bucket URL
# (e.g. https://pub-xxxx.r2.dev). Leave unset locally to use the public/assets
# junction. Must be NEXT_PUBLIC_ so client components can inline it.
NEXT_PUBLIC_ASSET_BASE_URL=

# Credentials for scripts/upload-to-r2.mjs (npm run upload-assets). These are
# only needed to push the asset library to R2 — not needed at runtime.
R2_ACCOUNT_ID=fb6c96add9dfcefd5f3722a2020122fc
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=united-marketing-assets
